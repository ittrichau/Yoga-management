# Bắt buộc - Secret key để mã hóa JWT token
# Đặt giá trị ngẫu nhiên, ít nhất 32 ký tự
SECRET_KEY=thay-doi-gia-tri-nay-bang-chuoi-ngau-nhien

# Tùy chọn - Secret key cho NiceGUI storage
STORAGE_SECRET=gym-nutrition-secret

# Tùy chọn - Tài khoản admin mặc định (chỉ dùng khi seed lần đầu)
SUPER_USER_USERNAME=admin
SUPER_USER_PASSWORD=admin123

# PostgreSQL URL (chỉ dùng khi deploy Railway)
# Railway sẽ tự inject DATABASE_URL, không cần set thủ công
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
